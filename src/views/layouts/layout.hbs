<!DOCTYPE html>
<html lang="en-IE">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
        <!-- Page title passed in from the controller -->
    <title>{{title}}</title>

    <!-- Bulma CSS framework -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.4/css/bulma.min.css">
    <!-- Font Awesome icons -->
    <script src="https://use.fontawesome.com/releases/v5.15.4/js/all.js"></script>
  </head>
  <body>
    <div class="container">
       <!-- Main page content injected by each view -->
      {{{content}}}
       <!-- Partial for displaying validation or server errors -->
      {{>error}}
    </div>
  </body>
</html>