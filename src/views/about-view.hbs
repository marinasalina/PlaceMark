{{> menu active="about"}}

<section class="section">
  <div class="box">
    <div class="columns is-vcentered">
    <div class="column is-half">
      
      <div class="column is-full has-text-centered">
        <h3 class="title">{{title}}</h3>
        <p>PlaceMark: Discover, organise, and manage your favourite places across the world </p></p>
      </div>
    </div>

<section class="section">
  <div class="box">
     <div class="columns is-vcentered"></div>
     <div class="column is-half">
      {{> icons/attention}}
    </div>

<div class="column is-half"></div>
    <h1 class="title has-text-centered"> Weather Station Dashboard Guide</h1>
      <p><h4>Welcome to your personal weather station dashboard! Here's how to use it:</h4></p>
      <ul>
        <li><strong>View Station Reports:</strong> Click the <em>Open</em> button next to a station to see detailed weather data, recent reports, and trends.</li>
        <li><strong>Add Reports:</strong> Use the <em>Add Report</em> section to submit new weather readings like temperature, wind speed, and pressure.</li>
        <li><strong>Edit or Delete Reports:</strong> Each report has edit  and delete buttons for quick changes.</li>
        <li><strong>Weather Summary:</strong> Each station displays the latest weather, including temperature, wind, pressure, and a weather icon.</li>
        <li><strong>Live Forecast & Trends:</strong> View forecasted temperature trends and a map with your station’s location.</li>
      </ul>
      <p>Enjoy monitoring the weather with your dashboard!</p>
    </div>
  </div>
  </div>
</section>