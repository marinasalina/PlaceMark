<!--  Include the main navigation menu and highlight the About tab-->
{{> menu active="about"}}

<section class="section">
  <div class="box">

    <!-- Header Section -->
    <div class="columns is-centered">
      <div class="column is-8 has-text-centered">
        <h3 class="title">{{title}}</h3>
        <p>PlaceMark: Discover, organise, and manage your favourite places across the world.</p>
      </div>
    </div>

  </div>
</section>

<section class="section">
  <div class="box">

    <div class="columns is-vcentered">

      <!-- Left Column: Icon -->
      <div class="column is-4 has-text-centered">
        {{> icons/attention}}
      </div>

      <!-- Right Column: POI Guide -->
      <div class="column is-8">
        <h1 class="title has-text-centered">Point of Interest (POI) Dashboard Guide</h1>

        <h4>Welcome to your POI dashboard! Here's how to use it:</h4>

        <ul>
          <li><strong>View POI Details:</strong> Click the <em>Open</em> button beside any point of interest to see its full information, including description, category, and location.</li>

          <li><strong>Add New POIs:</strong> Use the <em>Add POI</em> section to create new entries. A POI can include a name, coordinates, category, and any additional details you want to store.</li>

          <li><strong>Edit or Delete POIs:</strong> Each POI includes <em>Edit</em> and <em>Delete</em> options so you can update or remove locations quickly.</li>

          <li><strong>POI Summary:</strong> Each entry displays key information such as title, description, category, and geographic coordinates.</li>
        </ul>

        <p>Enjoy exploring and managing your Points of Interest!</p>
      </div>

    </div>

  </div>
</section>


