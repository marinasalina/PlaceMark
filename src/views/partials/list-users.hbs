<table class="table">
  <thead>
    <tr>
      <th>First Name</th>
      <th>Last Name</th>
      <th>Email</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {{#each users}}
      <tr>
        <td>{{firstName}}</td>
        <td>{{lastName}}</td>
        <td>{{email}}</td>
        <td>
          <a
            href="/admin/users/delete/{{_id}}"
            class="button is-danger is-small"
          >
            Delete
          </a>
        </td>
      </tr>
    {{/each}}
  </tbody>
</table>